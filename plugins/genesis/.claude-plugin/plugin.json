{
  "name": "genesis",
  "version": "0.1.0",
  "description": "Build production-ready software from idea to deployment. Gated 10-stage SDLC; stage skills orchestrate 11 role agents; state lives in the target project's docs/sdlc/state.json; approvals and status are zero-token hooks.",
  "author": { "name": "gypsy5oul", "email": "vishnuraveendran@gmail.com", "url": "https://github.com/gypsy5oul" },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact|resume",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-session-start.js\"", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-prompt-hook.js\"", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-state-guard.js\"", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/graph-index.js\"", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/usage-tracker.js\"", "timeout": 10 }
        ]
      }
    ]
  }
}
